<div class="success-card">
    <div class="success-icon">✓</div>
    <div class="success-message">
        <h3>Submission Successful!</h3>
        <p>Thank you, <strong>
                <%= name %>
            </strong>. We've received your registration for <strong>
                <%= email %>
            </strong> and our team will be in touch soon.</p>
    </div>
    <button type="button" class="btn-ghost" d-pulse="refresh" d-target="#form-surface">Start Over</button>
</div>